# Web (Vite) build-time variables. Copy to web/.env and edit, then rebuild:
#   cp web/.env.example web/.env
#   npm run build        # (or restart `npm run dev`)
#
# These are read via import.meta.env and BAKED INTO THE BUNDLE at build time.
# They are NOT the backend's .env (the one loaded by `uv run --env-file .env`),
# and changing them without rebuilding has no effect.
#
# For local dev against `temporal server start-dev` you don't need any of these;
# the defaults below match the local setup.

# Base URL of the Temporal Web UI the workflow links point to.
# Local dev server default: http://localhost:8233
# Temporal Cloud:           https://cloud.temporal.io
VITE_TEMPORAL_UI=http://localhost:8233

# Namespace segment used in the workflow link.
# Local dev server: default
# Temporal Cloud:   <namespace>.<accountId>  (e.g. my-app.a1b2c3)
VITE_TEMPORAL_NAMESPACE=default

# API origin the browser calls. Leave empty for same-origin (the Vite dev proxy
# handles /api locally). Set this only when the deployed UI talks to an API on a
# different origin.
# VITE_API_BASE=https://your-api-host

# Where the Vite dev server proxies /api during local dev. Defaults to the local
# FastAPI server; usually no need to change.
# VITE_API_TARGET=http://localhost:8000
