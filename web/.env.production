# Production build-time variables (Vite). Loaded automatically by `npm run build`
# (production mode) and BAKED INTO THE BUNDLE — local `npm run dev` is unaffected
# and still uses the localhost defaults documented in web/.env.example.
#
# These power the "view the workflow" deep link in TransferPlanCard.tsx:
#   ${VITE_TEMPORAL_UI}/namespaces/${VITE_TEMPORAL_NAMESPACE}/workflows/<id>
#
# NOTE: setting these as runtime pod env vars has NO effect — Vite inlines them
# at build time. To change them, edit here and rebuild the web image.
VITE_TEMPORAL_UI=https://cloud.temporal.io
VITE_TEMPORAL_NAMESPACE=tmprl-dem-cld-durable-banking-skills.a2dd6
