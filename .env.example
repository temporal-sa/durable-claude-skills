# Copy to .env and fill in your key:  cp .env.example .env
# Loaded into the API/worker with:    uv run --env-file .env ...

# Required — the agent API calls Claude with this key (agent/agent.py).
ANTHROPIC_API_KEY=sk-ant-...

# Optional — the Claude model the agent uses. Default below; a more capable
# option is claude-opus-4-8.
CLAUDE_MODEL=claude-sonnet-4-6

# Optional — Temporal frontend address and namespace. These defaults match
# `temporal server start-dev`, so you usually don't need to set them.
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default

# Optional — where the simulated bank's SQLite file lives. Defaults to
# ./banking.db in the working directory. The worker and API must agree on this,
# so if you change it, set it for both processes.
BANK_DB_PATH=./banking.db

# Optional — CORS origins the API accepts (comma-separated). Defaults cover the
# Vite dev server.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
